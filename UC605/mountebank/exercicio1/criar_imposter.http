    // Exercício 13 (com token)
    {
      "predicates": [
        {
          "equals": {
            "method": "GET",
            "path": "/api/profile",
            "headers": {
              "Authorization": "Bearer validtoken"
            }
          }
        }
      ],
      "responses": [
        {
          "is": {
            "statusCode": 200,
            "headers": {
              "Content-Type": "application/json"
            },
            "body": "{\"username\": \"admin\", \"email\": \"admin@example.com\", \"role\": \"administrator\"}"
          }
        }
      ]
    },

    // Exercício 13 (sem token)
    {
      "predicates": [
        {
          "equals": {
            "method": "GET",
