    // Exercício 12 (credenciais certas)
    {
      "predicates": [
        {
          "equals": {
            "method": "POST",
            "path": "/api/auth",
            "headers": {
              "Content-Type": "application/json"
            }
          }
        },
        {
          "deepEquals": {
            "body": {
              "username": "user1",
              "password": "pass1"
            }
          }
        }
      ],
      "responses": [
        {
          "is": {
            "statusCode": 200,
            "headers": {
              "Content-Type": "application/json"
            },
            "body": "{\"token\": \"authtoken123\", \"expires_in\": 3600}"
          }
        }
      ]
    },

    // Exercício 12 (credenciais erradas)
    {
      "predicates": [
        {
