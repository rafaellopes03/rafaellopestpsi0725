            "method": "POST",
            "path": "/api/auth",
            "headers": {
              "Content-Type": "application/json"
            }
          }
        }
      ],
      "responses": [
        {
          "is": {
            "statusCode": 401,
            "headers": {
              "Content-Type": "application/json"
            },
            "body": "{\"error\": \"invalid_credentials\"}"
